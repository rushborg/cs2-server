<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>RushBMatchTelemetry</RootNamespace>
    <AssemblyName>RushBMatchTelemetry</AssemblyName>
    <OutputType>Library</OutputType>
    <!-- Do not ship CSS API DLLs — server already has them. -->
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <!-- Pin to the exact CSS version the server image uses (see entrypoint.sh
         CSSHARP_URL). Keep these in sync when bumping CSS. -->
    <PackageReference Include="CounterStrikeSharp.API" Version="1.0.364">
      <Private>false</Private>
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
